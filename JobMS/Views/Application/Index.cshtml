@model IEnumerable<JobMS.Models.Application>

@{
    ViewData["Title"] = "Application List";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
    }

    .card-custom {
        border-radius: 15px;
        overflow: hidden;
        transition: 0.3s;
    }

    .card-custom:hover {
        transform: scale(1.03);
        box-shadow: 0 10px 25px rgba(0,0,0,0.3);
    }

    .table thead {
        background-color: #343a40;
        color: #fff;
    }

    .btn-custom {
        border-radius: 20px;
        padding: 5px 15px;
    }
</style>

<div class="container mt-5">

    <div class="text-center mb-4">
        <h1 class="fw-bold">📋 Application List</h1>
        <p>Manage all job applications easily</p>
    </div>

    <div class="card card-custom bg-light text-dark p-4">

        <div class="d-flex justify-content-between mb-3">
            <h4>All Applications</h4>
            <a asp-action="CreateOrEdit" class="btn btn-success btn-custom">➕ New Application</a>
        </div>

        <table class="table table-hover table-bordered text-center align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Degree</th>
                    <th>University</th>
                    <th>Salary</th>
                    <th>Expected</th>
                    <th>Year</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Degree</td>
                        <td>@item.University</td>
                        <td>@item.PresentSalary</td>
                        <td>@item.ExpectionSalary</td>
                        <td>@item.CompletionYear</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm btn-custom">👁</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm btn-custom">✏</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm btn-custom">🗑</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>