@model IEnumerable<JobMS.Models.Application>

@{
    ViewData["Title"] = "Application List";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />

<style>
    body {
        background: linear-gradient(135deg, #1f1c2c, #928dab);
        color: #fff;
    }

    .glass-card {
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(15px);
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.4);
    }

    .table {
        color: #fff;
    }

    .table thead {
        background: rgba(0,0,0,0.4);
    }

    .btn-custom {
        border-radius: 25px;
        padding: 5px 15px;
    }

    .title {
        font-weight: bold;
        letter-spacing: 1px;
    }
</style>

<div class="container mt-5">

    <div class="text-center mb-4">
        <h1 class="title">📋 Application Dashboard</h1>
        <p>Manage all job applications in one place</p>
    </div>

    <div class="glass-card">

        <div class="d-flex justify-content-between mb-3">
            <h4>All Applications</h4>

            <a asp-action="CreateOrEdit" class="btn btn-success btn-custom">
                ➕ New Application
            </a>
        </div>

        <div class="table-responsive">

            <table class="table table-hover align-middle text-center">

                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Degree</th>
                        <th>University</th>
                        <th>Salary</th>
                        <th>Expected</th>
                        <th>Year</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>
                                <i class="fa fa-user"></i> @item.Name
                            </td>

                            <td>@item.Degree</td>

                            <td>@item.University</td>

                            <td>💰 @item.PresentSalary</td>

                            <td>💸 @item.ExpectionSalary</td>

                            <td>📅 @item.CompletionYear</td>

                            <td>

                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-info btn-sm btn-custom">
                                    👁
                                </a>

                                <a asp-action="CreateOrEdit" asp-route-id="@item.Id"
                                   class="btn btn-warning btn-sm btn-custom">
                                    ✏
                                </a>

                                <!-- ✅ SAFE DELETE -->
                                <form asp-action="Delete" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit"
                                            class="btn btn-danger btn-sm btn-custom"
                                            onclick="return confirm('Are you sure?')">
                                        🗑
                                    </button>
                                </form>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>