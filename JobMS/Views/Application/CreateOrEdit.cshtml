@model JobMS.Models.Application



<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background: linear-gradient(135deg, #1d2671, #c33764);
        color: #fff;
    }

    .form-container {
        background: #ffffff;
        color: #000;
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }

    .form-control {
        border-radius: 10px;
    }

    .btn-custom {
        border-radius: 25px;
        padding: 8px 20px;
    }

    .title-text {
        font-weight: bold;
    }
</style>

<div class="container mt-5">

    <div class="text-center mb-4">
        <h1 class="title-text">
            @(Model.Id == 0 ? "🚀 Create Application" : "✏ Edit Application")
        </h1>
        <p>Fill the form carefully</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-10 form-container">

            <form asp-action="Save">
                <input type="hidden" asp-for="Id" />

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label>Name</label>
                        <input asp-for="Name" class="form-control" placeholder="Enter name" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Application ID</label>
                        <input asp-for="ApplicationId" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Present Salary</label>
                        <input asp-for="PresentSalary" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Expected Salary</label>
                        <input asp-for="ExpectionSalary" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Degree</label>
                        <input asp-for="Degree" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>University</label>
                        <input asp-for="University" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>CGPA</label>
                        <input asp-for="CGPA" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Completion Year</label>
                        <input asp-for="CompletionYear" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Resume</label>
                        <input asp-for="ResumePath" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Job</label>
                        <select asp-for="JobId" class="form-control" asp-items="ViewBag.JobList">
                            <option value="">-- Select Job --</option>
                        </select>
                    </div>

                </div>

                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-success btn-custom">
                        💾 Save
                    </button>

                    <a asp-action="Index" class="btn btn-secondary btn-custom">
                        🔙 Back
                    </a>
                </div>

            </form>

        </div>
    </div>
</div>