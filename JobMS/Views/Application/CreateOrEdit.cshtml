@model JobMS.Models.Application

@{
    var isEdit = Model != null && Model.Id != 0;
    ViewData["Title"] = isEdit ? "Edit Application" : "Create Application";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
        color: #fff;
    }

    .glass-card {
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(15px);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.4);
    }

    .form-control, .form-select {
        border-radius: 12px;
        border: none;
        padding: 10px;
    }

    .form-control:focus, .form-select:focus {
        box-shadow: 0 0 10px #00c6ff;
    }

    label {
        font-weight: 500;
        margin-bottom: 5px;
    }

    .btn-custom {
        border-radius: 30px;
        padding: 8px 25px;
    }

    .title {
        font-weight: bold;
        letter-spacing: 1px;
    }
</style>

<div class="container mt-5">

    <div class="text-center mb-4">
        <h1 class="title">
            @(isEdit ? "✏ Edit Application" : "🚀 Create Application")
        </h1>
        <p>Fill all required information carefully</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10 glass-card">

            <form asp-action="CreateOrEdit">
                <input type="hidden" asp-for="Id" />

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label>Name</label>
                        <input asp-for="Name" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Application ID</label>
                        <input asp-for="ApplicationId" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Present Salary</label>
                        <input asp-for="PresentSalary" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Expected Salary</label>
                        <input asp-for="ExpectionSalary" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Degree</label>
                        <input asp-for="Degree" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>University</label>
                        <input asp-for="University" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>CGPA</label>
                        <input asp-for="CGPA" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Completion Year</label>
                        <input asp-for="CompletionYear" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Resume</label>
                        <input asp-for="ResumePath" class="form-control" />
                    </div>

                    <!-- 🔥 Best Part (Dropdown from master) -->
                    <div class="col-md-6 mb-3">
                        <label>Job</label>
                        <select asp-for="JobId" class="form-control" asp-items="ViewBag.JobList">
                            <option value="">-- Select Job --</option>
                        </select>
                    </div>

                </div>

                <div class="text-center mt-4">

                    <button type="submit" class="btn btn-success btn-custom">
                        💾 Save
                    </button>

                    <a asp-action="Index" class="btn btn-light btn-custom">
                        🔙 Back
                    </a>

                </div>

            </form>

        </div>
    </div>
</div>