@model IEnumerable<JobMS.Models.Job>

@{
    ViewData["Title"] = "Available Jobs";
    Layout = "_LayoutPublic";
}

<div class="container py-5">
    <div class="glass-container">
        <!-- Header -->
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-5">
            <div>
                <h1 class="display-5 fw-bold mb-1">
                    <i class="fas fa-briefcase me-3" style="color: var(--teal);"></i>
                    Available Jobs
                </h1>
                <p class="text-muted fs-5 mb-0">Discover your next career opportunity</p>
            </div>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="row g-4">
                @foreach (var job in Model)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="job-card">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="job-title mb-0">@job.JobTitle</h5>
                                <span class="badge @(job.Status == "Active" ? "bg-success" : "bg-danger") px-3 py-2">
                                    @job.Status
                                </span>
                            </div>

                            <div class="job-description mb-4">
                                @(string.IsNullOrEmpty(job.Description)
                                                        ? "No description provided."
                                                        : (job.Description.Length > 160
                                                        ? job.Description.Substring(0, 160) + "..."
                                                        : job.Description))
                    </div>

                            <div class="job-meta mt-auto mb-4">
                                <div class="d-flex align-items-center gap-3 mb-2">
                                    <i class="fas fa-money-bill-wave" style="color: var(--teal); width: 22px;"></i>
                                    <span class="fw-medium">@(string.IsNullOrEmpty(job.SalaryRange) ? "Salary not specified" : job.SalaryRange)</span>
                                </div>
                                <div class="d-flex align-items-center gap-3">
                                    <i class="fas fa-calendar-alt" style="color: var(--teal); width: 22px;"></i>
                                    <span class="fw-medium">@(job.Deadline?.ToString("dd MMM yyyy") ?? "No deadline")</span>
                                </div>
                            </div>

                            <div class="d-flex gap-2 mt-auto">
                                <a asp-action="ViewDetails" asp-route-id="@job.Id"
                                   class="btn btn-dark flex-grow-1">
                                    <i class="fas fa-eye me-2"></i> View Details
                                </a>
                                <a asp-controller="Application" asp-action="CreateOrEdit" asp-route-jobId="@job.Id"
                                   class="btn btn-apply flex-grow-1 text-white">
                                    <i class="fas fa-paper-plane me-2"></i> Apply Now
                                </a>
                            </div>
                        </div>
                    </div>
                        }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <div class="mb-4">
                    <i class="fas fa-briefcase" style="font-size: 4.5rem; color: #64748b; opacity: 0.6;"></i>
                </div>
                <h4 class="mb-2">No Open Positions Right Now</h4>
                <p class="text-muted">We're always growing. Please check back soon for new opportunities.</p>
            </div>
        }

        <div class="text-center mt-5 pt-4 border-top border-secondary">
            <small class="text-muted">
                <i class="fas fa-shield-alt me-1"></i> All applications are processed securely
            </small>
        </div>
    </div>
</div>