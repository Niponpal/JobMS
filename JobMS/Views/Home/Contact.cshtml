@{
    Layout = "_LayoutPublic";
    ViewData["Title"] = "Contact Us";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-11">

            <!-- Header -->
            <div class="text-center mb-5">
                <h1 class="display-5 fw-bold text-dark mb-3">Get In Touch</h1>

                <p class="lead text-muted mb-2">
                    Have questions about jobs, employers, or applications?<br />
                    Our support team is ready to help you.
                </p>

                <div class="d-inline-flex align-items-center gap-2 text-success">
                    <i class="fa-solid fa-clock"></i>
                    <span>We usually reply within 2 business hours</span>
                </div>
            </div>

            <div class="row g-5">

                <!-- Left Side -->
                <div class="col-lg-5">

                    <!-- Contact Info -->
                    <div class="contact-card p-5 rounded-4 shadow-sm bg-white border">

                        <h3 class="fw-semibold mb-4 text-dark">
                            Contact Information
                        </h3>

                        <div class="contact-item d-flex mb-4">
                            <div class="icon-box me-4">
                                <i class="fa-solid fa-location-dot"></i>
                            </div>

                            <div>
                                <strong>Dhaka, Bangladesh</strong><br />
                                <span class="text-muted">
                                    Mirpur-10, Dhaka 1216
                                </span>
                            </div>
                        </div>

                        <div class="contact-item d-flex mb-4">
                            <div class="icon-box me-4">
                                <i class="fa-solid fa-envelope"></i>
                            </div>

                            <div>
                                <strong>Email</strong><br />

                                <a href="mailto:support@jobms.com"
                                   class="text-decoration-none">
                                    support@jobms.com
                                </a>
                            </div>
                        </div>

                        <div class="contact-item d-flex mb-5">
                            <div class="icon-box me-4">
                                <i class="fa-solid fa-phone"></i>
                            </div>

                            <div>
                                <strong>Phone</strong><br />

                                <a href="tel:+8801234567890"
                                   class="text-decoration-none">
                                    +880 1234-567890
                                </a>
                            </div>
                        </div>

                        <h5 class="mb-3 text-dark">Follow Us</h5>

                        <div class="social-icons">
                            <a href="#">
                                <i class="fa-brands fa-facebook-f"></i>
                            </a>

                            <a href="#">
                                <i class="fa-brands fa-linkedin-in"></i>
                            </a>

                            <a href="#">
                                <i class="fa-brands fa-x-twitter"></i>
                            </a>

                            <a href="#">
                                <i class="fa-brands fa-youtube"></i>
                            </a>
                        </div>
                    </div>

                    <!-- Google Map -->
                    <div class="mt-4">
                        <h5 class="mb-3 ps-1 text-dark">
                            Our Location
                        </h5>

                        <div class="map-container rounded-4 overflow-hidden shadow-sm">

                            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3651.123456789!2d90.361234!3d23.810345!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3755b8b0b0b0b0b1%3A0x0000000000000000!2sMirpur-10%2C%20Dhaka!5e0!3m2!1sen!2sbd!4v1740000000000"
                                    width="100%"
                                    height="100%"
                                    style="border:0;"
                                    allowfullscreen=""
                                    loading="lazy"
                                    referrerpolicy="no-referrer-when-downgrade">
                            </iframe>

                        </div>
                    </div>

                </div>

                <!-- Right Side -->
                <div class="col-lg-7">

                    <div class="card border-0 shadow rounded-4">

                        <div class="card-body p-5">

                            <h3 class="fw-semibold mb-4 text-dark">
                                Send Us a Message
                            </h3>

                            <form asp-action="Contact" method="post">

                                <div class="row">

                                    <div class="col-md-6 mb-4">
                                        <label class="form-label">
                                            Full Name
                                        </label>

                                        <input type="text"
                                               class="form-control form-control-lg"
                                               placeholder="Your full name"
                                               required />
                                    </div>

                                    <div class="col-md-6 mb-4">
                                        <label class="form-label">
                                            Email Address
                                        </label>

                                        <input type="email"
                                               class="form-control form-control-lg"
                                               placeholder="you@example.com"
                                               required />
                                    </div>

                                </div>

                                <div class="mb-4">
                                    <label class="form-label">
                                        Subject
                                    </label>

                                    <input type="text"
                                           class="form-control form-control-lg"
                                           placeholder="Job Application Support"
                                           required />
                                </div>

                                <div class="mb-4">
                                    <label class="form-label">
                                        Message
                                    </label>

                                    <textarea rows="7"
                                              class="form-control form-control-lg"
                                              placeholder="How can we help you today?"
                                              required></textarea>
                                </div>

                                <button type="submit"
                                        class="btn btn-primary btn-lg w-100 py-3 fw-semibold">

                                    <i class="fa-solid fa-paper-plane me-2"></i>
                                    Send Message

                                </button>

                            </form>

                        </div>

                    </div>

                </div>

            </div>
        </div>
    </div>
</div>

<style>

    :root {
        --primary: #0d6efd;
    }

    body {
        background: #f8f9fc;
    }

    .contact-card {
        background: #fff;
        border: 1px solid #e9ecef;
    }

    .icon-box {
        width: 52px;
        height: 52px;
        background: #f1f3f5;
        color: var(--primary);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .contact-item {
        transition: 0.3s ease;
    }

        .contact-item:hover {
            transform: translateX(8px);
        }

    .social-icons a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        background: #f8f9fa;
        color: #495057;
        border-radius: 50%;
        margin-right: 10px;
        font-size: 1.2rem;
        transition: 0.3s ease;
    }

        .social-icons a:hover {
            background: var(--primary);
            color: white;
            transform: translateY(-4px);
        }

    .form-control {
        border-radius: 12px;
        border: 2px solid #e0e0e0;
        padding: 14px 18px;
        font-size: 1rem;
        transition: 0.3s ease;
    }

        .form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 .25rem rgba(13,110,253,.15);
        }

    .form-label {
        font-weight: 600;
        margin-bottom: 8px;
        color: #444;
    }

    .btn-primary {
        border: none;
        border-radius: 12px;
        transition: 0.3s ease;
    }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(13,110,253,.25);
        }

    .card {
        transition: 0.4s ease;
    }

        .card:hover {
            transform: translateY(-8px);
            box-shadow: 0 25px 50px rgba(0,0,0,.12) !important;
        }

    .map-container {
        height: 420px;
    }

    @@media (max-width: 768px) {
        .map-container

    {
        height: 300px;
    }

    .contact-card {
        padding: 2rem !important;
    }

    .card-body {
        padding: 2rem !important;
    }

    }
</style>