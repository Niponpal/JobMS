@model JobMS.Models.Job
@{
    ViewData["Title"] = Model?.JobTitle ?? "Job Details";
    Layout = "_LayoutPublic";
}

<div class="container py-5">
    <div class="job-detail-wrapper">

        <!-- Back Button -->
        <div class="mb-4">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i> Back to All Jobs
            </a>
        </div>

        @if (Model != null)
        {
            <div class="row g-4">
                <!-- Main Content -->
                <div class="col-lg-8">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body p-5">

                            <!-- Header -->
                            <div class="d-flex justify-content-between align-items-start mb-4">
                                <div>
                                    <h1 class="display-6 fw-bold job-title">@Model.JobTitle</h1>
                                    @if (!string.IsNullOrEmpty(Model.CompanyName))
                                    {
                                        <h5 class="text-muted mt-2">@Model.CompanyName</h5>
                                    }
                                </div>
                                <span class="badge @(Model.Status == "Active" ? "bg-success" : "bg-danger") px-4 py-2 fs-6">
                                    <i class="fas fa-circle me-1" style="font-size: 0.65rem;"></i>
                                    @Model.Status
                                </span>
                            </div>

                            <!-- Job Meta Badges -->
                            <div class="d-flex flex-wrap gap-2 mb-5">
                                @if (!string.IsNullOrEmpty(Model.EmploymentStatus))
                                {
                                    <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2">@Model.EmploymentStatus</span>
                                }
                                @if (!string.IsNullOrEmpty(Model.Gender))
                                {
                                    <span class="badge bg-info bg-opacity-10 text-info px-3 py-2">@Model.Gender</span>
                                }
                                @if (!string.IsNullOrEmpty(Model.JobLocation))
                                {
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary px-3 py-2">
                                        <i class="fas fa-map-marker-alt me-1"></i> @Model.JobLocation
                                    </span>
                                }
                            </div>

                            <!-- Job Description -->
                            <div class="mb-5">
                                <h5 class="section-title">
                                    <i class="fas fa-align-left me-2"></i> Job Description
                                </h5>
                                <div class="job-content">
                                    @if (string.IsNullOrEmpty(Model.Description))
                                    {
                                        <p class="text-muted fst-italic">No description provided.</p>
                                    }
                                    else
                                    {
                                        <p style="white-space: pre-line; line-height: 1.85;">@Model.Description</p>
                                    }
                                </div>
                            </div>

                            <!-- Responsibilities -->
                            @if (!string.IsNullOrEmpty(Model.Responsibilities))
                            {
                                <div class="mb-5">
                                    <h5 class="section-title">
                                        <i class="fas fa-list-check me-2"></i> Responsibilities
                                    </h5>
                                    <div class="job-content">
                                        <p style="white-space: pre-line; line-height: 1.85;">@Model.Responsibilities</p>
                                    </div>
                                </div>
                            }

                            <!-- Skills & Expertise -->
                            @if (!string.IsNullOrEmpty(Model.SkillsAndExpertise))
                            {
                                <div class="mb-5">
                                    <h5 class="section-title">
                                        <i class="fas fa-tools me-2"></i> Skills & Expertise
                                    </h5>
                                    <div class="job-content">
                                        <p style="white-space: pre-line; line-height: 1.85;">@Model.SkillsAndExpertise</p>
                                    </div>
                                </div>
                            }

                            <!-- Additional Requirements -->
                            @if (!string.IsNullOrEmpty(Model.AdditionalRequirements))
                            {
                                <div class="mb-5">
                                    <h5 class="section-title">
                                        <i class="fas fa-clipboard-list me-2"></i> Additional Requirements
                                    </h5>
                                    <div class="job-content">
                                        <p style="white-space: pre-line; line-height: 1.85;">@Model.AdditionalRequirements</p>
                                    </div>
                                </div>
                            }

                            <!-- Education & Experience -->
                            <div class="row g-4">
                                @if (!string.IsNullOrEmpty(Model.Education))
                                {
                                    <div class="col-md-6">
                                        <h5 class="section-title">
                                            <i class="fas fa-graduation-cap me-2"></i> Education
                                        </h5>
                                        <p class="job-content">@Model.Education</p>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(Model.Experience))
                                {
                                    <div class="col-md-6">
                                        <h5 class="section-title">
                                            <i class="fas fa-briefcase me-2"></i> Experience
                                        </h5>
                                        <p class="job-content">@Model.Experience</p>
                                    </div>
                                }
                            </div>

                        </div>
                    </div>
                </div>

                <!-- Sidebar -->
                <div class="col-lg-4">
                    <div class="sticky-top" style="top: 90px;">

                        <!-- Job Information Card -->
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-body p-4">
                                <h6 class="text-muted mb-4 fw-semibold">Job Information</h6>

                                @if (!string.IsNullOrEmpty(Model.SalaryRange))
                                {
                                    <div class="meta-row">
                                        <i class="fas fa-money-bill-wave"></i>
                                        <div>
                                            <small class="text-muted">Salary Range</small>
                                            <p class="fw-semibold mb-0">@Model.SalaryRange</p>
                                        </div>
                                    </div>
                                }

                                @if (!string.IsNullOrEmpty(Model.JobLocation))
                                {
                                    <div class="meta-row">
                                        <i class="fas fa-map-marker-alt"></i>
                                        <div>
                                            <small class="text-muted">Location</small>
                                            <p class="fw-semibold mb-0">@Model.JobLocation</p>
                                        </div>
                                    </div>
                                }

                                @if (Model.Deadline.HasValue)
                                {
                                    <div class="meta-row">
                                        <i class="fas fa-calendar-day"></i>
                                        <div>
                                            <small class="text-muted">Deadline</small>
                                            <p class="fw-semibold mb-0">@Model.Deadline.Value.ToString("dd MMMM yyyy")</p>
                                        </div>
                                    </div>
                                }

                                <div class="meta-row">
                                    <i class="fas fa-clock"></i>
                                    <div>
                                        <small class="text-muted">Posted On</small>
                                        <p class="fw-semibold mb-0">@Model.CreatedAt.ToString("dd MMMM yyyy")</p>
                                    </div>
                                </div>

                                @if (!string.IsNullOrEmpty(Model.EmploymentStatus))
                                {
                                    <div class="meta-row">
                                        <i class="fas fa-user-tie"></i>
                                        <div>
                                            <small class="text-muted">Employment Type</small>
                                            <p class="fw-semibold mb-0">@Model.EmploymentStatus</p>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Apply Button -->
                        <a asp-controller="Application" asp-action="CreateOrEdit"
                           asp-route-jobId="@Model.Id"
                           class="btn btn-primary btn-lg w-100 py-3 fs-5 fw-semibold shadow">
                            <i class="fas fa-paper-plane me-2"></i> Apply Now
                        </a>

                        <div class="text-center mt-4">
                            <small class="text-muted">
                                <i class="fas fa-lock me-1"></i> Secure & Confidential Application
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <h3 class="text-muted">Sorry, this job posting is not available.</h3>
                <a asp-action="Index" class="btn btn-primary mt-3">Browse All Jobs</a>
            </div>
        }
    </div>
</div>

@section Styles {
    <style>
        .job-detail-wrapper {
            max-width: 1280px;
            margin: 0 auto;
        }

        .section-title {
            font-size: 1.25rem;
            font-weight: 600;
            color: #0d6efd;
            margin-bottom: 1.25rem;
            padding-bottom: 0.75rem;
            border-bottom: 2px solid #e9ecef;
        }

        [data-bs-theme="dark"] .section-title {
            color: #60a5fa;
            border-bottom-color: #495057;
        }

        .job-title {
            color: #1e2937;
        }

        [data-bs-theme="dark"] .job-title {
            color: #f8fafc;
        }

        .job-content {
            color: #475569;
            line-height: 1.85;
            font-size: 1.05rem;
        }

        [data-bs-theme="dark"] .job-content {
            color: #cbd5e1;
        }

        .meta-row {
            display: flex;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 1.4rem;
        }

            .meta-row i {
                font-size: 1.35rem;
                width: 34px;
                color: #0d6efd;
            }

        [data-bs-theme="dark"] .meta-row i {
            color: #60a5fa;
        }

        .card {
            border-radius: 16px;
        }
    </style>
}