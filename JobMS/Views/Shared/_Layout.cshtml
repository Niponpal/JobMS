<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - JobMS</title>

    <!-- Bootstrap 5.3 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />



    <!-- Custom Styles -->
    <style>
        :root {
            --primary: #4F46E5;
            --primary-dark: #4338CA;
            --teal: #14B8A6;
            --sidebar-bg: #1E2937;
            --sidebar-width: 260px;
            --sidebar-collapsed: 72px;
        }

        body {
            background: #F8FAFC;
            font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        }

        /* Sidebar */
        .sidebar {
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            color: white;
            transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 1050;
            overflow-y: auto;
            box-shadow: 4px 0 20px rgba(0, 0, 0, 0.15);
        }

            .sidebar.collapsed {
                width: var(--sidebar-collapsed);
            }

        .sidebar-header {
            padding: 1.75rem 1.25rem;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            font-size: 1.6rem;
            font-weight: 700;
            letter-spacing: -0.03em;
        }

        .nav-link {
            color: rgba(255, 255, 255, 0.9);
            padding: 0.85rem 1.25rem;
            display: flex;
            align-items: center;
            border-radius: 0.75rem;
            margin: 0.25rem 0.75rem;
            transition: all 0.25s ease;
        }

        .sidebar.collapsed .nav-link {
            justify-content: center;
            padding: 0.9rem 0.6rem;
        }

        .nav-link i {
            width: 28px;
            text-align: center;
            margin-right: 12px;
            font-size: 1.25rem;
        }

        .sidebar.collapsed .nav-link i {
            margin-right: 0;
            font-size: 1.4rem;
        }

        .sidebar.collapsed .nav-link span {
            display: none;
        }

        .nav-link:hover,
        .nav-link.active {
            background: rgba(255, 255, 255, 0.15);
            color: white;
        }

        /* Main Content */
        .main-content {
            margin-left: var(--sidebar-width);
            transition: margin-left 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            min-height: 100vh;
        }

        .sidebar.collapsed + .main-content {
            margin-left: var(--sidebar-collapsed);
        }

        /* Top Navbar */
        .top-navbar {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid #E2E8F0;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
        }

        .stat-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

            .stat-card:hover {
                transform: translateY(-6px);
                box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Sidebar -->
    <nav class="sidebar" id="sidebar">
        <div class="sidebar-header d-flex align-items-center">
            <i class="fas fa-briefcase me-3 fs-3" style="color: #14B8A6;"></i>
            <span>JobMS</span>
        </div>

        <div class="mt-3 px-2">
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link active" asp-controller="Dashboard" asp-action="Index">
                        <i class="fas fa-tachometer-alt"></i>
                        <span>Dashboard</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Job" asp-action="Index">
                        <i class="fas fa-list"></i>
                        <span>Manage Jobs</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Application" asp-action="Index">
                        <i class="fas fa-file-alt"></i>
                        <span>Applications</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Users" asp-action="Index">
                        <i class="fas fa-users"></i>
                        <span>Users</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Reports" asp-action="Index">
                        <i class="fas fa-chart-bar"></i>
                        <span>Reports</span>
                    </a>
                </li>
            </ul>
        </div>

        <div class="mt-auto p-3">
            <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout">
                <i class="fas fa-sign-out-alt"></i>
                <span>Logout</span>
            </a>
        </div>
    </nav>

    <!-- Main Content Area -->
    <div class="main-content">
        <!-- Top Navbar -->
        <nav class="navbar top-navbar navbar-expand-lg px-4 py-3">
            <div class="container-fluid">
                <!-- Sidebar Toggle -->
                <button class="btn btn-link text-dark me-3 d-lg-none" id="mobileToggle">
                    <i class="fas fa-bars fs-3"></i>
                </button>

                <button class="btn btn-link text-dark d-none d-lg-block me-3" id="collapseToggle">
                    <i class="fas fa-bars fs-3" id="collapseIcon"></i>
                </button>

                <div class="ms-auto d-flex align-items-center gap-4">
                    <span class="fw-medium text-dark d-none d-md-inline">
                        Welcome, <strong>@User.Identity?.Name</strong>
                    </span>

                    <!-- Theme Toggle -->
                    <button class="btn btn-light rounded-circle p-2" id="themeToggle">
                        <i class="fas fa-moon" id="themeIcon"></i>
                    </button>

                    <!-- User Profile -->
                    <div class="dropdown">
                        <a class="d-flex align-items-center text-decoration-none dropdown-toggle"
                           href="#" data-bs-toggle="dropdown">
                            <i class="fas fa-user-circle fa-2x text-secondary"></i>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow">
                            <li><a class="dropdown-item" href="#">Profile</a></li>
                            <li><a class="dropdown-item" href="#">Settings</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit" class="dropdown-item text-danger">Logout</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>

        <!-- Page Content -->
        <main class="p-4 p-lg-5">
            @RenderBody()
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
 

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>


    <script>
        // Sidebar Collapse Toggle (Desktop)
        const sidebar = document.getElementById('sidebar');
        const collapseToggle = document.getElementById('collapseToggle');
        const collapseIcon = document.getElementById('collapseIcon');

        collapseToggle?.addEventListener('click', () => {
            sidebar.classList.toggle('collapsed');
            collapseIcon.className = sidebar.classList.contains('collapsed')
                ? 'fas fa-bars fs-3'
                : 'fas fa-compress-alt fs-3';
        });

        // Mobile Toggle
        document.getElementById('mobileToggle')?.addEventListener('click', () => {
            sidebar.style.transform = sidebar.style.transform === 'translateX(-100%)'
                ? 'translateX(0)'
                : 'translateX(-100%)';
        });

        // Simple Theme Toggle (Light/Dark)
        const themeToggle = document.getElementById('themeToggle');
        const themeIcon = document.getElementById('themeIcon');
        let isDark = false;

        themeToggle?.addEventListener('click', () => {
            isDark = !isDark;
            document.documentElement.setAttribute('data-bs-theme', isDark ? 'dark' : 'light');
            themeIcon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
        });

        // Close mobile sidebar when clicking outside (optional enhancement)
        document.addEventListener('click', (e) => {
            if (window.innerWidth < 992 && !sidebar.contains(e.target) && e.target.id !== 'mobileToggle') {
                sidebar.style.transform = 'translateX(-100%)';
            }
        });
    </script>


    <!-- ⭐ Notification Partial -->
    <partial name="_Notification" />

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
