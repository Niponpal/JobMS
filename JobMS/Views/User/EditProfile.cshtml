@using JobMS.Auth_IdentityModel
@model User

@{
   
    ViewData["Title"] = "Edit Profile";
}

<div class="min-vh-100 d-flex align-items-center py-5"
     style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-xl-6">

                <!-- Main Card -->
                <div class="card border-0 shadow-2xl rounded-5 overflow-hidden"
                     style="background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(20px);">

                    <!-- Header -->
                    <div class="bg-gradient text-white p-5 text-center"
                         style="background: linear-gradient(135deg, #4c6ef5, #6b4eff);">
                        <h2 class="fw-bold mb-1">Edit Profile</h2>
                        <p class="mb-0 opacity-75">Update your personal information</p>
                    </div>

                    <div class="card-body p-5">

                        <form asp-action="EditProfile" method="post" enctype="multipart/form-data">

                            <!-- Profile Picture Preview -->
                            <div class="text-center mb-5">
                                <div class="position-relative d-inline-block">
                                    <img id="imagePreview"
                                         src="@(string.IsNullOrEmpty(Model?.ImageUrl)
                                                                                      ? "https://cdn-icons-png.flaticon.com/512/3135/3135715.png"
                                                                                      : Url.Content("~/" + Model.ImageUrl))"
                                         class="rounded-circle shadow border border-5 border-white"
                                         style="width: 160px; height: 160px; object-fit: cover;" />

                                    <label for="ProfileImage"
                                           class="position-absolute bottom-0 end-0 bg-primary text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm"
                                           style="width: 45px; height: 45px; cursor: pointer; border: 4px solid white;">
                                        ✏️
                                    </label>
                                </div>
                                <div class="mt-3">
                                    <small class="text-muted">Click the pencil icon to change photo</small>
                                </div>
                            </div>

                            <!-- Hidden file input -->
                            <input type="file" name="ProfileImage" id="ProfileImage"
                                   class="d-none" accept="image/*" onchange="previewImage(this)" />

                            <!-- UserName Field -->
                            <div class="mb-4">
                                <label asp-for="UserName" class="form-label fw-semibold text-dark"></label>
                                <input asp-for="UserName" class="form-control form-control-lg shadow-sm"
                                       placeholder="Enter your full name" />
                                <span asp-validation-for="UserName" class="text-danger"></span>
                            </div>

                            <!-- Email (Read Only) -->
                            <div class="mb-4">
                                <label class="form-label fw-semibold text-dark">Email Address</label>
                                <input type="email" value="@Model.Email"
                                       class="form-control form-control-lg shadow-sm bg-light" readonly />
                                <small class="text-muted">Email cannot be changed</small>
                            </div>

                            <!-- Current Image Info -->
                            @if (!string.IsNullOrEmpty(Model?.ImageUrl))
                            {
                                <div class="mb-4">
                                    <label class="form-label fw-semibold text-dark">Current Profile Image</label>
                                    <p class="text-muted small">@Model.ImageUrl</p>
                                </div>
                            }

                            <hr class="my-4">

                            <!-- Action Buttons -->
                            <div class="d-flex gap-3 justify-content-end mt-4">
                                <a asp-controller="User" asp-action="Profile"
                                   class="btn btn-outline-secondary px-5 py-3 rounded-pill">
                                    Cancel
                                </a>
                                <button type="submit" class="btn btn-primary px-5 py-3 rounded-pill shadow-sm fw-semibold">
                                    💾 Save Changes
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Help text -->
                <div class="text-center mt-4">
                    <small class="text-white-50">
                        All changes will be reflected immediately after saving
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- JavaScript for Live Image Preview -->
<script>
    function previewImage(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function (e) {
                document.getElementById('imagePreview').src = e.target.result;
            }
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>