@model JobMS.Models.Job

@{
    ViewData["Title"] = "Job Details";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />

<style>
    body {
        background: linear-gradient(135deg, #141e30, #243b55);
        color: #fff;
    }

    .glass-card {
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(15px);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.4);
    }

    .info-box {
        background: rgba(255,255,255,0.12);
        padding: 15px;
        border-radius: 12px;
        margin-bottom: 15px;
    }

    .label {
        font-size: 13px;
        opacity: 0.7;
        font-weight: bold;
    }

    .value {
        font-size: 16px;
        margin-top: 5px;
    }

    .badge-active {
        background-color: #28a745;
        padding: 5px 12px;
        border-radius: 20px;
    }

    .badge-inactive {
        background-color: #dc3545;
        padding: 5px 12px;
        border-radius: 20px;
    }

    .btn-custom {
        border-radius: 30px;
        padding: 8px 20px;
    }

    .title {
        font-weight: bold;
        letter-spacing: 1px;
    }
</style>

<div class="container mt-5">

    <div class="text-center mb-4">
        <h1 class="title">💼 Job Details</h1>
        <p>Complete information about the job post</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10 glass-card">

            <div class="row">

                <div class="col-md-6">

                    <div class="info-box">
                        <div class="label"><i class="fa fa-id-badge"></i> Job ID</div>
                        <div class="value">@Model.JobID</div>
                    </div>

                    <div class="info-box">
                        <div class="label"><i class="fa fa-briefcase"></i> Job Title</div>
                        <div class="value">@Model.JobTitle</div>
                    </div>

                    <div class="info-box">
                        <div class="label"><i class="fa fa-align-left"></i> Description</div>
                        <div class="value">@Model.Description</div>
                    </div>

                </div>

                <div class="col-md-6">

                    <div class="info-box">
                        <div class="label"><i class="fa fa-money-bill"></i> Salary Range</div>
                        <div class="value">@Model.SalaryRange</div>
                    </div>

                    <div class="info-box">
                        <div class="label"><i class="fa fa-calendar"></i> Deadline</div>
                        <div class="value">@Model.Deadline?.ToString("dd MMM yyyy")</div>
                    </div>

                    <div class="info-box">
                        <div class="label"><i class="fa fa-info-circle"></i> Status</div>
                        <div class="value">
                            @if (Model.Status == "Active")
                            {
                                <span class="badge-active">Active</span>
                            }
                            else
                            {
                                <span class="badge-inactive">Inactive</span>
                            }
                        </div>
                    </div>

                    <div class="info-box">
                        <div class="label"><i class="fa fa-clock"></i> Created At</div>
                        <div class="value">@Model.CreatedAt.ToString("dd MMM yyyy")</div>
                    </div>

                </div>

            </div>

            <div class="text-center mt-4">

                <a asp-action="CreateOrEdit" asp-route-id="@Model.Id"
                   class="btn btn-warning btn-custom">
                    ✏ Edit
                </a>

                <a asp-action="Index"
                   class="btn btn-light btn-custom">
                    🔙 Back
                </a>

            </div>

        </div>
    </div>

</div>