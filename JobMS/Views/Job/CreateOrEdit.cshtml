@model JobMS.Models.Job
@{
    var isEdit = Model != null && Model.Id != 0;
    ViewData["Title"] = isEdit ? "Edit Job" : "Create New Job";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

<style>
    :root {
        --form-bg: #ffffff;
    }

    [data-bs-theme="dark"] {
        --form-bg: #1e1e2f;
    }

    .form-container {
        max-width: 920px;
        margin: 2rem auto;
        background: var(--form-bg);
        border-radius: 12px;
        box-shadow: 0 10px 35px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        transition: all 0.3s ease;
    }

    .form-header {
        background: linear-gradient(135deg, #0d6efd, #0a58ca);
        color: white;
        padding: 2rem;
        text-align: center;
    }

    [data-bs-theme="dark"] .form-header {
        background: linear-gradient(135deg, #0b5ed7, #084298);
    }

    .section-title {
        font-size: 1.15rem;
        font-weight: 600;
        color: #495057;
        margin: 2rem 0 1.25rem 0;
        padding-bottom: 0.75rem;
        border-bottom: 2px solid #e9ecef;
    }

    [data-bs-theme="dark"] .section-title {
        color: #adb5bd;
        border-bottom-color: #495057;
    }

    .form-control, .form-select {
        border-radius: 8px;
        padding: 0.7rem 1rem;
    }

    textarea.form-control {
        min-height: 130px;
        resize: vertical;
    }

    .btn-save {
        padding: 0.75rem 2.5rem;
        font-weight: 600;
        border-radius: 8px;
    }

    .theme-toggle {
        position: absolute;
        top: 20px;
        right: 30px;
        z-index: 100;
    }
</style>

<div class="container mt-4">
  

    <div class="form-container">
        <!-- Header -->
        <div class="form-header">
            <h2 class="mb-1">
                <i class="fas fa-briefcase me-2"></i>
                @(isEdit ? "Edit Job Posting" : "Create New Job Posting")
            </h2>
            <p class="mb-0 opacity-75">
                @(isEdit ? "Update the job details" : "Fill in the details to post a new job")
            </p>
        </div>

        <div class="p-4 p-md-5">
            <form asp-action="CreateOrEdit" method="post">
                <input type="hidden" asp-for="Id" />

                <!-- Basic Information -->
                <h5 class="section-title">Basic Information</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="JobID" class="form-label fw-medium"></label>
                        <input asp-for="JobID" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="JobTitle" class="form-label fw-medium"></label>
                        <input asp-for="JobTitle" class="form-control" placeholder="e.g. Senior Software Engineer" />
                    </div>
                    <div class="col-12">
                        <label asp-for="Description" class="form-label fw-medium"></label>
                        <textarea asp-for="Description" class="form-control"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EmploymentStatus" class="form-label fw-medium"></label>
                        <input asp-for="EmploymentStatus" class="form-control" placeholder="Full-time, Part-time, Contract" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Gender" class="form-label fw-medium"></label>
                        <input asp-for="Gender" class="form-control" placeholder="Any / Male / Female" />
                    </div>
                </div>

                <!-- Company -->
                <h5 class="section-title">Company Information</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="CompanyName" class="form-label fw-medium"></label>
                        <input asp-for="CompanyName" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label asp-for="CompanyInformation" class="form-label fw-medium"></label>
                        <textarea asp-for="CompanyInformation" class="form-control"></textarea>
                    </div>
                </div>

                <!-- Location & Salary -->
                <h5 class="section-title">Location & Compensation</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="JobLocation" class="form-label fw-medium"></label>
                        <input asp-for="JobLocation" class="form-control" placeholder="Dhaka, Bangladesh / Remote" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="SalaryRange" class="form-label fw-medium"></label>
                        <input asp-for="SalaryRange" class="form-control" placeholder="BDT 80,000 - 1,50,000" />
                    </div>
                    <div class="col-12">
                        <label asp-for="CompensationAndBenefits" class="form-label fw-medium"></label>
                        <textarea asp-for="CompensationAndBenefits" class="form-control"></textarea>
                    </div>
                </div>

                <!-- Skills -->
                <h5 class="section-title">Skills & Responsibilities</h5>
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="SkillsAndExpertise" class="form-label fw-medium"></label>
                        <textarea asp-for="SkillsAndExpertise" class="form-control"></textarea>
                    </div>
                    <div class="col-12">
                        <label asp-for="Responsibilities" class="form-label fw-medium"></label>
                        <textarea asp-for="Responsibilities" class="form-control"></textarea>
                    </div>
                </div>

                <!-- Requirements -->
                <h5 class="section-title">Requirements & Qualifications</h5>
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="AdditionalRequirements" class="form-label fw-medium"></label>
                        <textarea asp-for="AdditionalRequirements" class="form-control"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Experience" class="form-label fw-medium"></label>
                        <input asp-for="Experience" class="form-control" placeholder="3-5 years" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Education" class="form-label fw-medium"></label>
                        <input asp-for="Education" class="form-control" placeholder="Bachelor's / Master's" />
                    </div>
                </div>

                <!-- Deadline & Status -->
                <h5 class="section-title">Other Information</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Deadline" class="form-label fw-medium"></label>
                        <input asp-for="Deadline" type="date" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Status" class="form-label fw-medium"></label>
                        <select asp-for="Status" class="form-select">
                            <option value="Active">Active</option>
                            <option value="Inactive">Inactive</option>
                        </select>
                    </div>
                </div>

                <!-- Buttons -->
                <div class="d-flex justify-content-center gap-3 mt-5">
                    <button type="submit" class="btn btn-primary btn-save">
                        <i class="fas fa-save me-2"></i> Save Job
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-save">
                        <i class="fas fa-arrow-left me-2"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    const themeToggle = document.getElementById('themeToggle');
    const html = document.documentElement;

    // Load saved theme or default to light
    function loadTheme() {
        const savedTheme = localStorage.getItem('theme') || 'light';
        html.setAttribute('data-bs-theme', savedTheme);
        updateIcon(savedTheme);
    }

    function updateIcon(theme) {
        themeToggle.innerHTML = theme === 'dark'
            ? '<i class="fas fa-sun"></i>'
            : '<i class="fas fa-moon"></i>';
    }

    // Toggle theme
    themeToggle.addEventListener('click', () => {
        const currentTheme = html.getAttribute('data-bs-theme');
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';

        html.setAttribute('data-bs-theme', newTheme);
        localStorage.setItem('theme', newTheme);
        updateIcon(newTheme);
    });

    // Initialize
    loadTheme();
</script>



