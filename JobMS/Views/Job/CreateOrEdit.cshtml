@model JobMS.Models.Job

@{
    var isEdit = Model != null && Model.Id != 0;
    ViewData["Title"] = isEdit ? "Edit Job" : "Create Job";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />

<style>
    body {
        background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
        color: #fff;
    }

    .glass-box {
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(15px);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.4);
    }

    .form-control, .form-select {
        border-radius: 12px;
        border: none;
        padding: 10px;
    }

        .form-control:focus, .form-select:focus {
            box-shadow: 0 0 10px #00c6ff;
        }

    .btn-custom {
        border-radius: 30px;
        padding: 8px 25px;
    }

    .title {
        font-weight: bold;
        letter-spacing: 1px;
    }

    label {
        font-weight: 500;
        margin-bottom: 5px;
    }
</style>

<div class="container mt-5">

    <div class="text-center mb-4">
        <h1 class="title">
            @(isEdit ? "✏ Edit Job" : "🚀 Create Job")
        </h1>
        <p>Fill job information carefully</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10 glass-box">

            <form asp-action="CreateOrEdit">

                <input type="hidden" asp-for="Id" />

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label>Job ID</label>
                        <input asp-for="JobID" class="form-control" placeholder="Enter Job ID" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Job Title</label>
                        <input asp-for="JobTitle" class="form-control" placeholder="Enter Job Title" />
                    </div>

                    <div class="col-md-12 mb-3">
                        <label>Description</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Salary Range</label>
                        <input asp-for="SalaryRange" class="form-control" placeholder="e.g. 30k - 50k" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Deadline</label>
                        <input asp-for="Deadline" type="date" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Status</label>
                        <select asp-for="Status" class="form-select">
                            <option value="Active">Active</option>
                            <option value="Inactive">Inactive</option>
                        </select>
                    </div>

                </div>

                <div class="text-center mt-4">

                    <button type="submit" class="btn btn-success btn-custom">
                        💾 Save
                    </button>

                    <a asp-action="Index" class="btn btn-light btn-custom">
                        🔙 Back
                    </a>

                </div>

            </form>

        </div>
    </div>
</div>