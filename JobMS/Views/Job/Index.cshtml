@model IEnumerable<JobMS.Models.Job>

@{
    ViewData["Title"] = "Job List";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />

<style>
    body {
        background: linear-gradient(135deg, #1e3c72, #2a5298);
        color: #fff;
    }

    .card-glass {
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(12px);
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }

    .job-card {
        background: rgba(255,255,255,0.15);
        border-radius: 15px;
        padding: 20px;
        transition: 0.3s;
        height: 100%;
    }

        .job-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.4);
        }

    .badge-active {
        background-color: #28a745;
    }

    .badge-inactive {
        background-color: #dc3545;
    }

    .btn-custom {
        border-radius: 25px;
        padding: 5px 15px;
    }
</style>

<div class="container mt-5">

    <div class="text-center mb-4">
        <h1>💼 Job Management</h1>
        <p>Manage all job postings easily</p>
    </div>

    <div class="card-glass">

        <div class="d-flex justify-content-between mb-4">
            <h4>All Jobs</h4>
            <a asp-action="CreateOrEdit" class="btn btn-success btn-custom">
                ➕ Add Job
            </a>
        </div>

        <div class="row">

            @foreach (var job in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="job-card">

                        <h5 class="fw-bold">@job.JobTitle</h5>

                        <p class="text-light">
                            @(job.Description?.Length > 80
                                                    ? job.Description.Substring(0, 80) + "..."
                                                    : job.Description)
                    </p>

                        <div class="mb-2">
                            <i class="fa fa-money-bill"></i>
                            <strong>@job.SalaryRange</strong>
                        </div>

                        <div class="mb-2">
                            <i class="fa fa-calendar"></i>
                            @job.Deadline?.ToString("dd MMM yyyy")
                        </div>

                        <div class="mb-2">
                        @if (job.Status == "Active")
                            {
                                <span class="badge badge-active">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-inactive">Inactive</span>
                            }
                        </div>

                        <div class="d-flex justify-content-between mt-3">

                            <a asp-action="Details" asp-route-id="@job.Id"
                               class="btn btn-info btn-sm btn-custom">
                                👁
                            </a>

                            <a asp-action="CreateOrEdit" asp-route-id="@job.Id"
                               class="btn btn-warning btn-sm btn-custom">
                                ✏
                            </a>

                            <form asp-action="Delete" method="post" asp-route-id="@job.Id">
                                <button type="submit" class="btn btn-danger btn-sm btn-custom">
                                    🗑
                                </button>
                            </form>

                        </div>

                    </div>
                </div>
            }

        </div>

    </div>
</div>