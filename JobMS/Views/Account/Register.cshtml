@model JobMS.Models.Auth.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background: linear-gradient(135deg, #667eea, #764ba2);
        height: 100vh;
    }

    .register-card {
        border-radius: 20px;
        backdrop-filter: blur(10px);
        background: rgba(255, 255, 255, 0.1);
        box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        color: white;
    }

    .form-control {
        border-radius: 10px;
        padding: 12px;
    }

    .btn-custom {
        border-radius: 10px;
        background: linear-gradient(45deg, #ff6a00, #ee0979);
        border: none;
        font-weight: bold;
    }

    .btn-custom:hover {
        opacity: 0.9;
    }

    .title {
        font-weight: bold;
        letter-spacing: 1px;
    }

    .icon {
        margin-right: 8px;
    }
</style>

<div class="container d-flex justify-content-center align-items-center" style="height:100vh;">
    <div class="col-md-5">
        <div class="card register-card p-4">

            <h2 class="text-center title mb-4">✨ Create Account</h2>

            <form asp-action="Register" asp-controller="Account" method="post" enctype="multipart/form-data">

                <div asp-validation-summary="ModelOnly" class="text-warning"></div>

                <!-- Name -->
                <div class="mb-3">
                    <label class="form-label">👤 Full Name</label>
                    <input asp-for="Name" class="form-control" placeholder="Enter your name" />
                    <span asp-validation-for="Name" class="text-warning"></span>
                </div>

                <!-- Email -->
                <div class="mb-3">
                    <label class="form-label">📧 Email</label>
                    <input asp-for="Email" class="form-control" placeholder="Enter your email" />
                    <span asp-validation-for="Email" class="text-warning"></span>
                </div>

                <!-- Password -->
                <div class="mb-3">
                    <label class="form-label">🔒 Password</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" />
                    <span asp-validation-for="Password" class="text-warning"></span>
                </div>

                <!-- Phone -->
                <div class="mb-3">
                    <label class="form-label">📱 Phone Number</label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="Enter phone" />
                    <span asp-validation-for="PhoneNumber" class="text-warning"></span>
                </div>

                <!-- Image Upload -->
                <div class="mb-3">
                    <label class="form-label">🖼 Upload Image</label>
                    <input asp-for="ImageFile" type="file" class="form-control" />
                </div>

                <!-- Button -->
                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-custom btn-lg">
                        🚀 Register Now
                    </button>
                </div>

                <div class="text-center mt-3">
                    <small>
                        Already have an account?
                        <a asp-action="Login" asp-controller="Account" class="text-white fw-bold">Login</a>
                    </small>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}