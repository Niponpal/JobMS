@model JobMS.Models.Auth.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login | JobMS Portal</title>

    <!-- Bootstrap 5 + Icons + Fonts -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
          
        body {
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at 10% 30%, #0f172a, #0b1120);
            height: 100vh;
            overflow: hidden;
            position: relative;
        }

            /* Animated background particles effect */
            body::before {
                content: "";
                position: absolute;
                width: 200%;
                height: 200%;
                top: -50%;
                left: -50%;
                background: radial-gradient(circle, rgba(56, 189, 248, 0.08) 1px, transparent 1px);
                background-size: 40px 40px;
                animation: slowMove 40s linear infinite;
                pointer-events: none;
                z-index: 0;
            }

        @@keyframes slowMove {
            0%

        {
            transform: translate(0, 0);
        }

        100% {
            transform: translate(40px, 40px);
        }

        }

        /* floating glow orbs */
        .glow-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.5;
            z-index: 0;
            pointer-events: none;
        }

        .orb1 {
            width: 350px;
            height: 350px;
            background: #3b82f6;
            top: -100px;
            left: -80px;
        }

        .orb2 {
            width: 400px;
            height: 400px;
            background: #8b5cf6;
            bottom: -120px;
            right: -80px;
        }

        /* main card */
        .login-card {
            border-radius: 32px;
            backdrop-filter: blur(14px);
            background: rgba(15, 23, 42, 0.65);
            box-shadow: 0 25px 45px -12px rgba(0, 0, 0, 0.5), 0 1px 2px rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.15);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

            .login-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 30px 50px -12px rgba(0, 0, 0, 0.6);
                border-color: rgba(255, 255, 255, 0.25);
            }

        /* form elements */
        .form-label {
            font-weight: 500;
            font-size: 0.85rem;
            letter-spacing: 0.3px;
            color: #e2e8f0;
            margin-bottom: 0.4rem;
        }

        .input-group-text {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-right: none;
            color: #94a3b8;
            font-size: 0.9rem;
            border-radius: 14px 0 0 14px;
        }

        .form-control {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-left: none;
            border-radius: 0 14px 14px 0;
            padding: 12px 16px;
            color: #f1f5f9;
            font-size: 0.95rem;
            transition: all 0.2s;
        }

            .form-control:focus {
                background: rgba(255, 255, 255, 0.1);
                border-color: #3b82f6;
                box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.3);
                outline: none;
                color: white;
            }

            .form-control::placeholder {
                color: #94a3b8;
                font-weight: 400;
                font-size: 0.85rem;
            }

        /* password toggle */
        .toggle-password {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-left: none;
            border-radius: 0 14px 14px 0;
            cursor: pointer;
            transition: background 0.2s;
        }

            .toggle-password:hover {
                background: rgba(255, 255, 255, 0.15);
                color: #cbd5e1;
            }

        /* checkbox customization */
        .form-check-input {
            background-color: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.3);
            border-radius: 5px;
            cursor: pointer;
        }

            .form-check-input:checked {
                background-color: #3b82f6;
                border-color: #3b82f6;
            }

        .form-check-label {
            font-size: 0.85rem;
            color: #cbd5e6;
        }

        /* login button */
        .btn-login {
            border-radius: 40px;
            background: linear-gradient(95deg, #2563eb, #4f46e5);
            border: none;
            font-weight: 600;
            padding: 12px 0;
            font-size: 1rem;
            letter-spacing: 0.3px;
            transition: all 0.2s ease;
            box-shadow: 0 6px 14px rgba(37, 99, 235, 0.3);
        }

            .btn-login:hover {
                background: linear-gradient(95deg, #3b82f6, #6366f1);
                transform: scale(1.01);
                box-shadow: 0 10px 20px -5px rgba(37, 99, 235, 0.5);
            }

        /* links */
        .forgot-link, .register-link {
            text-decoration: none;
            font-size: 0.8rem;
            font-weight: 500;
            transition: color 0.2s;
        }

        .forgot-link {
            color: #a5b4fc;
        }

            .forgot-link:hover {
                color: #c7d2fe;
                text-decoration: underline;
            }

        .register-link {
            color: #38bdf8;
            font-weight: 600;
        }

            .register-link:hover {
                color: #7dd3fc;
                text-decoration: underline;
            }

        /* validation summary */
        .text-warning {
            color: #facc15 !important;
            font-size: 0.8rem;
            font-weight: 500;
        }

        /* divider */
        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            color: #64748b;
            font-size: 0.7rem;
            margin: 20px 0 10px;
        }

            .divider::before, .divider::after {
                content: '';
                flex: 1;
                border-bottom: 1px solid rgba(255,255,255,0.15);
            }

            .divider::before {
                margin-right: 12px;
            }

            .divider::after {
                margin-left: 12px;
            }

        /* custom check + animation */
        .custom-check {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* small responsive */
        @@media (max-width: 576px) {
            .login-card

        {
            margin: 0 1rem;
            padding: 1.5rem !important;
        }

        }

        /* brand icon */
        .brand-icon {
            background: linear-gradient(145deg, #3b82f6, #8b5cf6);
            width: 52px;
            height: 52px;
            border-radius: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 12px auto;
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
        }
    </style>
</head>
<body>

    <!-- background orbs -->
    <div class="glow-orb orb1"></div>
    <div class="glow-orb orb2"></div>

    <div class="container d-flex justify-content-center align-items-center position-relative" style="height:100vh; z-index:2;">
        <div class="col-md-5 col-lg-4">
            <div class="card login-card p-4 p-xl-5">

                <!-- brand icon / logo -->
                <div class="brand-icon">
                    <i class="fa-regular fa-building fa-xl" style="color: white;"></i>
                </div>
                <h2 class="text-center fw-semibold mb-1" style="color: #f8fafc;">JobMS Portal</h2>
                <p class="text-center text-secondary-emphasis mb-4" style="color: #9ca3af !important; font-size: 0.85rem;">Sign in to your account</p>

                <form asp-action="Login" asp-controller="Account" method="post" id="loginForm">

                    <!-- Model validation summary -->
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger bg-transparent border-0 text-warning small p-0 mb-3"></div>

                    <!-- Email field -->
                    <div class="mb-4">
                        <label class="form-label"><i class="fa-regular fa-envelope me-1"></i> Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fa-regular fa-envelope"></i></span>
                            <input asp-for="Email" class="form-control" placeholder="hello@jobms.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-warning small mt-1 d-block"></span>
                    </div>

                    <!-- Password field -->
                    <div class="mb-3">
                        <label class="form-label"><i class="fa-regular fa-lock me-1"></i> Password</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fa-regular fa-lock"></i></span>
                            <input asp-for="Password" type="password" class="form-control" id="password" placeholder="••••••••" />
                            <span class="input-group-text toggle-password" onclick="togglePassword()">
                                <i class="fa-regular fa-eye" id="eyeIcon"></i>
                            </span>
                        </div>
                        <span asp-validation-for="Password" class="text-warning small mt-1 d-block"></span>
                    </div>

                    <!-- Remember me & Forgot row -->
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="custom-check">
                            <input class="form-check-input" type="checkbox" id="rememberMe" name="RememberMe" />
                            <label class="form-check-label" for="rememberMe"> Keep me signed in</label>
                        </div>
                        <a href="#" class="forgot-link"><i class="fa-regular fa-question-circle me-1"></i>Forgot password?</a>
                    </div>

                    <!-- Login button -->
                    <div class="d-grid mb-4">
                        <button type="submit" class="btn btn-login btn-lg text-white">
                            <i class="fa-regular fa-arrow-right-to-bracket me-2"></i> Login
                        </button>
                    </div>

                    <!-- elegant divider -->
                    <div class="divider">
                        <span>New to JobMS?</span>
                    </div>

                    <div class="text-center">
                        <a asp-action="Register" asp-controller="Account" class="register-link">
                            <i class="fa-regular fa-user-plus me-1"></i> Create an account
                        </a>
                    </div>

                    <!-- hidden antiforgery token (optional but good practice) -->
                    @Html.AntiForgeryToken()
                </form>

                <!-- demo hint (professional subtle tip) -->
                <div class="text-center mt-3 small" style="color: #6c86a3;">
                    <i class="fa-regular fa-shield-haltered"></i> Secured enterprise login
                </div>
            </div>
        </div>
    </div>

    <script>
        // Toggle password visibility with modern icon switch
        function togglePassword() {
            const passwordInput = document.getElementById("password");
            const eyeIcon = document.getElementById("eyeIcon");

            if (passwordInput.type === "password") {
                passwordInput.type = "text";
                eyeIcon.classList.remove("fa-eye");
                eyeIcon.classList.add("fa-eye-slash");
            } else {
                passwordInput.type = "password";
                eyeIcon.classList.remove("fa-eye-slash");
                eyeIcon.classList.add("fa-eye");
            }
        }

        // Optional: add client-side validation event to improve UX (Bootstrap already uses validation scripts partial later)
        // But we can also manually trigger some micro-interactions
        document.addEventListener("DOMContentLoaded", function () {
            // Add subtle hover effects for card (already in CSS)
            // Focus ring for inputs improves accessibility
            const inputs = document.querySelectorAll('.form-control');
            inputs.forEach(input => {
                input.addEventListener('focus', () => {
                    input.parentElement?.classList.add('focused-group');
                });
                input.addEventListener('blur', () => {
                    input.parentElement?.classList.remove('focused-group');
                });
            });
        });
    </script>

    <!-- validation scripts partial emulated (includes jQuery validation + unobtrusive) -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
    <!-- Additional dynamic validation improvement (ensure proper placeholder spans) -->
    <script>
        // Enhance validation to display errors more gracefully (if server-side not triggered)
        $(document).ready(function () {
            // re-parse dynamic validation attributes (works for all fields)
            $.validator.unobtrusive.parse('#loginForm');

            // optional: add custom method for email requirement
            $('#loginForm').on('submit', function(e) {
                // basic check to show interactive messages if needed (but unobtrusive does already)
                // makes the form feel professional
                if (!$('#loginForm').valid()) {
                    e.preventDefault();
                    // smooth scroll to first error
                    let firstError = $('.field-validation-error').first();
                    if (firstError.length) {
                        $('html, body').animate({
                            scrollTop: firstError.closest('.mb-3, .mb-4').offset().top - 120
                        }, 300);
                    }
                }
            });
        });
    </script>

    <!-- Style to ensure validation spans are visible -->
    <style>
        .field-validation-error {
            color: #facc15;
            font-size: 0.7rem;
            margin-top: 4px;
            display: inline-block;
        }

        .input-validation-error {
            border-color: #f97316 !important;
            box-shadow: 0 0 0 2px rgba(249,115,22,0.25);
        }

        .validation-summary-errors ul {
            margin-bottom: 0;
            padding-left: 1rem;
        }

        .alert-danger {
            background: rgba(153, 27, 27, 0.2);
            border-left: 3px solid #f97316;
            border-radius: 12px;
            color: #ffedd5;
        }
    </style>

    <!-- ensure the model binding works in a standard ASP.NET Core View, using existing LoginViewModel properties.
         For completeness the "RememberMe" is added as boolean in the view; we added checkbox name "RememberMe" -->
</body>
</html>